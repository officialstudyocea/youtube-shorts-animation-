# ─────────────────────────────────────────────
#  YouTube Shorts Automation – Server Config
# ─────────────────────────────────────────────

PORT=5000

# MongoDB connection string
MONGODB_URI=mongodb://localhost:27017/shorts-automation

# Groq AI API Keys (Add as many as you want: GROQ_API_KEY_1, GROQ_API_KEY_2, etc.)
# Get keys at https://console.groq.com
GROQ_API_KEY_1=your_first_key_here
GROQ_API_KEY_2=your_second_key_here

# Gemini API Key (Primary Creative) → https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_key

# OpenRouter API Key (Backup Creative) → https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_key

# Redis Config (for Scheduler Queue)
REDIS_URL=redis://127.0.0.1:6379

# Max upload file size (bytes) – default 1 GB
MAX_FILE_SIZE=1073741824

# CORS allowed origin (your frontend URL)
CLIENT_URL=http://localhost:5173

# GitHub Automation Account
GITHUB_URL=https://github.com/officialstudyocea
